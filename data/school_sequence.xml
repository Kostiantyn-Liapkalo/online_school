<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- School Course Sequence -->
        <record id="seq_school_course" model="ir.sequence">
            <field name="name">School Course</field>
            <field name="code">school.course</field>
            <field name="prefix">COURSE-</field>
            <field name="padding">4</field>
            <field name="number_increment">1</field>
            <field name="company_id" eval="False"/>
        </record>

        <!-- School Student Sequence -->
        <record id="seq_school_student" model="ir.sequence">
            <field name="name">School Student</field>
            <field name="code">school.student</field>
            <field name="prefix">STU-</field>
            <field name="padding">5</field>
            <field name="number_increment">1</field>
            <field name="company_id" eval="False"/>
        </record>

        <!-- School Teacher Sequence -->
        <record id="seq_school_teacher" model="ir.sequence">
            <field name="name">School Teacher</field>
            <field name="code">school.teacher</field>
            <field name="prefix">TCH-</field>
            <field name="padding">4</field>
            <field name="number_increment">1</field>
            <field name="company_id" eval="False"/>
        </record>

        <!-- School Enrollment Sequence -->
        <record id="seq_school_enrollment" model="ir.sequence">
            <field name="name">School Enrollment</field>
            <field name="code">school.enrollment</field>
            <field name="prefix">ENR-</field>
            <field name="padding">5</field>
            <field name="number_increment">1</field>
            <field name="company_id" eval="False"/>
        </record>

        <!-- School Certificate Sequence -->
        <record id="seq_school_certificate" model="ir.sequence">
            <field name="name">School Certificate</field>
            <field name="code">school.certificate</field>
            <field name="prefix">CERT-</field>
            <field name="padding">6</field>
            <field name="number_increment">1</field>
            <field name="company_id" eval="False"/>
        </record>
    </data>
</odoo>
