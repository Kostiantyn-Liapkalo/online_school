<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Course Tree View -->
    <record id="view_school_course_tree" model="ir.ui.view">
        <field name="name">school.course.tree</field>
        <field name="model">school.course</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="code"/>
                <field name="teacher_id"/>
                <field name="state"/>
                <field name="difficulty"/>
                <field name="lesson_count"/>
                <field name="student_count"/>
            </list>
        </field>
    </record>

    <!-- Course Form View -->
    <record id="view_school_course_form" model="ir.ui.view">
        <field name="name">school.course.form</field>
        <field name="model">school.course</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_publish" string="Publish" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_archive" string="Archive" type="object" invisible="state == 'archived'"/>
                    <button name="action_draft" string="Set to Draft" type="object" invisible="state == 'draft'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,published,archived"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Course Name"/>
                        </h1>
                        <field name="code" readonly="1" class="oe_inline"/>
                    </div>
                    <group>
                        <group>
                            <field name="teacher_id"/>
                            <field name="difficulty"/>
                            <field name="duration_hours"/>
                        </group>
                        <group>
                            <field name="start_date"/>
                            <field name="end_date"/>
                            <field name="active" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description">
                            <field name="short_description" placeholder="Short description for course listings"/>
                            <field name="description" placeholder="Detailed course description"/>
                        </page>
                        <page string="Lessons">
                            <field name="lesson_ids">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="content_type"/>
                                    <field name="duration_minutes"/>
                                    <field name="state"/>
                                </list>
                            </field>
                        </page>
                        <page string="Enrollments">
                            <field name="enrollment_ids">
                                <list>
                                    <field name="student_id"/>
                                    <field name="state"/>
                                    <field name="enrollment_date"/>
                                    <field name="progress_percentage" widget="progressbar"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Course Search View -->
    <record id="view_school_course_search" model="ir.ui.view">
        <field name="name">school.course.search</field>
        <field name="model">school.course</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="code"/>
                <field name="teacher_id"/>
                <filter name="published" string="Published" domain="[('state', '=', 'published')]"/>
                <filter name="draft" string="Draft" domain="[('state', '=', 'draft')]"/>
                <filter name="archived" string="Archived" domain="[('state', '=', 'archived')]"/>
                <separator/>
                <filter name="group_by_teacher" string="Teacher" context="{'group_by': 'teacher_id'}"/>
                <filter name="group_by_difficulty" string="Difficulty" context="{'group_by': 'difficulty'}"/>
                <filter name="group_by_state" string="Status" context="{'group_by': 'state'}"/>
            </search>
        </field>
    </record>

    <record id="view_school_course_kanban" model="ir.ui.view">
        <field name="name">school.course.kanban</field>
        <field name="model">school.course</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state">
                <field name="name"/>
                <field name="code"/>
                <field name="teacher_id"/>
                <field name="difficulty"/>
                <field name="lesson_count"/>
                <field name="student_count"/>
                <templates>
                    <t t-name="card">
                        <div class="o_kanban_record">
                            <div class="o_kanban_record_top">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title">
                                        <field name="name"/>
                                    </strong>
                                    <div>
                                        <field name="code"/>
                                    </div>
                                </div>
                            </div>
                            <div class="o_kanban_record_body">
                                <div>
                                    <field name="teacher_id"/>
                                </div>
                                <div>
                                    <field name="difficulty"/>
                                </div>
                            </div>
                            <div class="o_kanban_record_bottom">
                                <div class="o_kanban_bottom_left">
                                    <span>
                                        <field name="lesson_count"/>
                                    </span>
                                    <span>
                                        <field name="student_count"/>
                                    </span>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Course Action -->
    <record id="action_school_course" model="ir.actions.act_window">
        <field name="name">Courses</field>
        <field name="res_model">school.course</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="search_view_id" ref="view_school_course_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first course
            </p>
            <p>
                Courses contain lessons and can have multiple enrolled students.
            </p>
        </field>
    </record>
</odoo>
